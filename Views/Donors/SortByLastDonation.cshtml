@model IEnumerable<BloodDonationManagementSystem.Models.Donor>

@{
    ViewData["Title"] = "Sorted Donors";
}

<h2>Donors Sorted by Last Donation Date</h2>

<table border="1" cellpadding="8">
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Blood Group</th>
        <th>Contact</th>
        <th>City</th>
        <th>Last Donation Date</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.DonorId</td>
            <td>@item.FullName</td>
            <td>@item.BloodGroup</td>
            <td>@item.ContactNo</td>
            <td>@item.City</td>
            <td>@item.LastDonationDate</td>
        </tr>
    }

</table>

<br />

<a href="/Donors">Back to Donor List</a>