@model IEnumerable<BloodDonationManagementSystem.Models.Donor>

@{
    ViewData["Title"] = "Donor List";
}

<h2 class="mt-4 mb-3 text-center text-danger">Blood Donor List</h2>

<p>
    <a href="/Donors/Create" class="btn btn-success">
        Add New Donor
    </a>
</p>

<table class="table table-bordered table-hover table-striped">
    <thead class="table-danger">
        <tr>
            <th>Donor ID</th>
            <th>Full Name</th>
            <th>Blood Group</th>
            <th>Contact No</th>
            <th>City</th>
            <th>Last Donation Date</th>
            <th width="260">Action</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.DonorId</td>
                <td>@item.FullName</td>
                <td>@item.BloodGroup</td>
                <td>@item.ContactNo</td>
                <td>@item.City</td>
                <td>@item.LastDonationDate</td>

                <td>

                    <a href="/Donors/Edit/@item.DonorId"
                       class="btn btn-warning btn-sm">
                        Edit
                    </a>

                    <a href="/Donors/Details/@item.DonorId"
                       class="btn btn-info btn-sm">
                        Details
                    </a>

                    <a href="/Donors/Delete/@item.DonorId"
                       class="btn btn-danger btn-sm">
                        Delete
                    </a>

                </td>
            </tr>
        }

    </tbody>

</table>

<hr />

<h4 class="text-primary">LINQ Features</h4>

<p>
    <a href="/Donors/Filter" class="btn btn-primary">
        Filter by Blood Group
    </a>

    <a href="/Donors/SortByLastDonation" class="btn btn-secondary">
        Sort by Last Donation
    </a>

    <a href="/Donors/DonationCount" class="btn btn-dark">
        Donation Count
    </a>

    <a href="/Donors/TotalBloodCollected" class="btn btn-success">
        Total Blood Collected
    </a>
</p>