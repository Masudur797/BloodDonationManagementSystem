@model BloodDonationManagementSystem.Models.Donor

@{
    ViewData["Title"] = "Edit Donor";
}

<div class="container mt-5">

    <div class="card shadow">

        <div class="card-header bg-warning text-dark">
            <h3 class="text-center mb-0">Edit Donor</h3>
        </div>

        <div class="card-body">

            <form method="post" action="/Donors/Edit/@Model.DonorId">

                <input type="hidden" name="DonorId" value="@Model.DonorId" />

                <div class="mb-3">
                    <label class="form-label"><b>Full Name</b></label>
                    <input type="text"
                           name="FullName"
                           value="@Model.FullName"
                           class="form-control" />

                    <span class="text-danger">
                        @Html.ValidationMessage("FullName")
                    </span>
                </div>

                <div class="mb-3">
                    <label class="form-label"><b>Blood Group</b></label>
                    <input type="text"
                           name="BloodGroup"
                           value="@Model.BloodGroup"
                           class="form-control" />

                    <span class="text-danger">
                        @Html.ValidationMessage("BloodGroup")
                    </span>
                </div>

                <div class="mb-3">
                    <label class="form-label"><b>Contact No</b></label>
                    <input type="text"
                           name="ContactNo"
                           value="@Model.ContactNo"
                           class="form-control" />

                    <span class="text-danger">
                        @Html.ValidationMessage("ContactNo")
                    </span>
                </div>

                <div class="mb-3">
                    <label class="form-label"><b>City</b></label>
                    <input type="text"
                           name="City"
                           value="@Model.City"
                           class="form-control" />

                    <span class="text-danger">
                        @Html.ValidationMessage("City")
                    </span>
                </div>

                <div class="mb-3">
                    <label class="form-label"><b>Last Donation Date</b></label>

                    <input type="date"
                           name="LastDonationDate"
                           value="@(Model.LastDonationDate?.ToString("yyyy-MM-dd"))"
                           class="form-control" />

                    <span class="text-danger">
                        @Html.ValidationMessage("LastDonationDate")
                    </span>
                </div>

                <div class="text-center">

                    <input type="submit"
                           value="Update Donor"
                           class="btn btn-warning" />

                    <a href="/Donors"
                       class="btn btn-secondary">
                        Back to List
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>