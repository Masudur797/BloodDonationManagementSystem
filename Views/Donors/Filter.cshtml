@model IEnumerable<BloodDonationManagementSystem.Models.Donor>

@{
    ViewData["Title"] = "Filter Donors";
}

<h2>Filter Donors by Blood Group</h2>

<form method="get" action="/Donors/Filter">

    <label>Select Blood Group</label>

    <select name="bloodGroup">
        <option value="">-- All --</option>
        <option value="A+">A+</option>
        <option value="A-">A-</option>
        <option value="B+">B+</option>
        <option value="B-">B-</option>
        <option value="AB+">AB+</option>
        <option value="AB-">AB-</option>
        <option value="O+">O+</option>
        <option value="O-">O-</option>
    </select>

    <input type="submit" value="Search" />

</form>

<br />

<table border="1" cellpadding="8">
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Blood Group</th>
        <th>Contact</th>
        <th>City</th>
        <th>Last Donation</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.DonorId</td>
            <td>@item.FullName</td>
            <td>@item.BloodGroup</td>
            <td>@item.ContactNo</td>
            <td>@item.City</td>
            <td>@item.LastDonationDate</td>
        </tr>
    }

</table>

<br />

<a href="/Donors">Back to Donor List</a>