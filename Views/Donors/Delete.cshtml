@model BloodDonationManagementSystem.Models.Donor

@{
    ViewData["Title"] = "Delete Donor";
}

<h2>Delete Donor</h2>

<h3>Are you sure you want to delete this donor?</h3>

<table border="1" cellpadding="8">
    <tr>
        <th>Full Name</th>
        <td>@Model.FullName</td>
    </tr>
    <tr>
        <th>Blood Group</th>
        <td>@Model.BloodGroup</td>
    </tr>
    <tr>
        <th>Contact No</th>
        <td>@Model.ContactNo</td>
    </tr>
    <tr>
        <th>City</th>
        <td>@Model.City</td>
    </tr>
    <tr>
        <th>Last Donation Date</th>
        <td>@Model.LastDonationDate</td>
    </tr>
</table>

<br />

<form method="post" action="/Donors/Delete/@Model.DonorId">
    <input type="hidden" name="DonorId" value="@Model.DonorId" />

    <input type="submit" value="Delete" />

    <a href="/Donors">Back to List</a>
</form>