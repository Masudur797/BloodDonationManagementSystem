@model BloodDonationManagementSystem.Models.Donor

@{
    ViewData["Title"] = "Delete Donor";
}

<div class="container mt-5">

    <div class="card shadow border-danger">

        <div class="card-header bg-danger text-white">
            <h3 class="text-center mb-0">Delete Donor</h3>
        </div>

        <div class="card-body">

            <div class="alert alert-warning text-center">
                <strong>Are you sure you want to delete this donor?</strong>
            </div>

            <table class="table table-bordered table-striped">

                <tr>
                    <th width="35%">Full Name</th>
                    <td>@Model.FullName</td>
                </tr>

                <tr>
                    <th>Blood Group</th>
                    <td>
                        <span class="badge bg-danger">
                            @Model.BloodGroup
                        </span>
                    </td>
                </tr>

                <tr>
                    <th>Contact No</th>
                    <td>@Model.ContactNo</td>
                </tr>

                <tr>
                    <th>City</th>
                    <td>@Model.City</td>
                </tr>

                <tr>
                    <th>Last Donation Date</th>
                    <td>@Model.LastDonationDate</td>
                </tr>

            </table>

            <form method="post" action="/Donors/Delete/@Model.DonorId">

                <input type="hidden"
                       name="DonorId"
                       value="@Model.DonorId" />

                <div class="text-center mt-4">

                    <input type="submit"
                           value="Delete Donor"
                           class="btn btn-danger" />

                    <a href="/Donors"
                       class="btn btn-secondary">
                        Back to List
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>