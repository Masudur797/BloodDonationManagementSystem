@model BloodDonationManagementSystem.Models.Donor

@{
    ViewData["Title"] = "Donor Details";
}

<h2>Donor Details</h2>

<table border="1" cellpadding="8">
    <tr>
        <th>Donor ID</th>
        <td>@Model.DonorId</td>
    </tr>

    <tr>
        <th>Full Name</th>
        <td>@Model.FullName</td>
    </tr>

    <tr>
        <th>Blood Group</th>
        <td>@Model.BloodGroup</td>
    </tr>

    <tr>
        <th>Contact No</th>
        <td>@Model.ContactNo</td>
    </tr>

    <tr>
        <th>City</th>
        <td>@Model.City</td>
    </tr>

    <tr>
        <th>Last Donation Date</th>
        <td>@Model.LastDonationDate</td>
    </tr>
</table>

<br />

<a href="/Donors/Edit/@Model.DonorId">Edit</a> |
<a href="/Donors">Back to List</a>