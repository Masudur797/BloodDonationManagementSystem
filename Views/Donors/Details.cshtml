@model BloodDonationManagementSystem.Models.Donor

@{
    ViewData["Title"] = "Donor Details";
}

<div class="container mt-5">

    <div class="card shadow">

        <div class="card-header bg-info text-white">
            <h3 class="text-center mb-0">Donor Details</h3>
        </div>

        <div class="card-body">

            <table class="table table-bordered table-striped">

                <tr>
                    <th width="35%">Donor ID</th>
                    <td>@Model.DonorId</td>
                </tr>

                <tr>
                    <th>Full Name</th>
                    <td>@Model.FullName</td>
                </tr>

                <tr>
                    <th>Blood Group</th>
                    <td>
                        <span class="badge bg-danger">
                            @Model.BloodGroup
                        </span>
                    </td>
                </tr>

                <tr>
                    <th>Contact No</th>
                    <td>@Model.ContactNo</td>
                </tr>

                <tr>
                    <th>City</th>
                    <td>@Model.City</td>
                </tr>

                <tr>
                    <th>Last Donation Date</th>
                    <td>@Model.LastDonationDate</td>
                </tr>

            </table>

            <div class="text-center mt-4">

                <a href="/Donors/Edit/@Model.DonorId"
                   class="btn btn-warning">
                    Edit
                </a>

                <a href="/Donors"
                   class="btn btn-secondary">
                    Back to List
                </a>

            </div>

        </div>

    </div>

</div>